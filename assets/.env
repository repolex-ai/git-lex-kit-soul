# git-lex agent identity — sourced on startup by the SessionStart hook.
# These values are used for git commits across all repos (soul + squad).
#
# The email domain here is a placeholder — edit it to match your squad's
# convention. Future versions of the kit may expose this as an init prompt.

GIT_AUTHOR_NAME="{agent_name}"
GIT_AUTHOR_EMAIL="{agent_name}@7r1pl3f0rc3.local"
GIT_COMMITTER_NAME="{agent_name}"
GIT_COMMITTER_EMAIL="{agent_name}@7r1pl3f0rc3.local"
