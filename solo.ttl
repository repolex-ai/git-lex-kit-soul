@prefix lex-o: <https://repolex.ai/ontology/lex-upper/> .
@prefix solo: <https://repolex.ai/ontology/kit/solo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# SOLO KIT ONTOLOGY
# =============================================================================
# Personal agent memory. One agent, one repo, persistent identity.
# Carries across conversations, sessions, and projects.
#
# Kit: solo
# Namespace: solo: = https://repolex.ai/ontology/kit/solo/
# Extends: lex-o: (upper ontology)
#
# Document types (= valid `git lex create` commands):
#   memory, decision, task, research, contact, note, journal
#
# Field naming convention:
#   plain string  — single literal value    (DatatypeProperty)
#   -list         — multiple literal values (DatatypeProperty, YAML list)
# Property types are declared by owl:DatatypeProperty / owl:ObjectProperty.
# SHACL shapes validate and document each field.
# =============================================================================

<https://repolex.ai/ontology/kit/solo> a owl:Ontology ;
    rdfs:label "Solo Kit Ontology" ;
    rdfs:comment "Personal agent memory. One agent, persistent identity across conversations and projects." ;
    owl:versionInfo "0.2" .


# =============================================================================
# DOCUMENT TYPES
# =============================================================================

# --- Memory ---
# A fact, observation, preference, or learned thing.
# The core unit of personal knowledge.

solo:Memory a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Memory" ;
    rdfs:comment "A fact, observation, preference, or lesson learned. The core unit of personal knowledge." .

solo:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:comment "How sure: 'certain', 'likely', 'hypothesis', 'hunch'." ;
    rdfs:domain solo:Memory ;
    rdfs:range xsd:string .

solo:source a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:comment "Where this memory came from: a conversation, document, experiment, observation." ;
    rdfs:domain solo:Memory ;
    rdfs:range xsd:string .

solo:category a owl:DatatypeProperty ;
    rdfs:label "category" ;
    rdfs:comment "Memory category: 'fact', 'preference', 'skill', 'observation', 'lesson', 'reference', 'decision'." ;
    rdfs:domain solo:Memory ;
    rdfs:range xsd:string .

# --- Decision ---
# A personal choice with context and rationale.

solo:Decision a owl:Class ;
    rdfs:subClassOf lex-o:Decision ;
    rdfs:label "Decision" ;
    rdfs:comment "A personal choice with context and rationale." .

solo:alternatives a owl:DatatypeProperty ;
    rdfs:label "alternatives" ;
    rdfs:comment "Other options that were considered." ;
    rdfs:domain solo:Decision ;
    rdfs:range xsd:string .

solo:rationale a owl:DatatypeProperty ;
    rdfs:label "rationale" ;
    rdfs:comment "Why this option was chosen." ;
    rdfs:domain solo:Decision ;
    rdfs:range xsd:string .

solo:outcome a owl:DatatypeProperty ;
    rdfs:label "outcome" ;
    rdfs:comment "What happened: 'pending', 'implemented', 'failed', 'superseded'." ;
    rdfs:domain solo:Decision ;
    rdfs:range xsd:string .

solo:supersededBy a owl:ObjectProperty ;
    rdfs:label "superseded by" ;
    rdfs:comment "A later decision that replaces this one." ;
    rdfs:domain solo:Decision ;
    rdfs:range solo:Decision .

# --- Task ---
# Something to do. Personal task tracking.

solo:Task a owl:Class ;
    rdfs:subClassOf lex-o:Process ;
    rdfs:label "Task" ;
    rdfs:comment "A personal work item or todo." .

solo:taskStatus a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "Task status: 'todo', 'in-progress', 'blocked', 'done', 'dropped'." ;
    rdfs:domain solo:Task ;
    rdfs:range xsd:string .

solo:priority a owl:DatatypeProperty ;
    rdfs:label "priority" ;
    rdfs:comment "Priority: 'low', 'normal', 'high', 'urgent'." ;
    rdfs:domain solo:Task ;
    rdfs:range xsd:string .

solo:blockedBy a owl:DatatypeProperty ;
    rdfs:label "blocked by" ;
    rdfs:comment "What's blocking this task (free text description)." ;
    rdfs:domain solo:Task ;
    rdfs:range xsd:string .

solo:project a owl:DatatypeProperty ;
    rdfs:label "project" ;
    rdfs:comment "Which project this task relates to." ;
    rdfs:domain solo:Task ;
    rdfs:range xsd:string .

# --- Research ---
# An ongoing investigation. Tracks threads of inquiry over time.

solo:Research a owl:Class ;
    rdfs:subClassOf lex-o:Process ;
    rdfs:label "Research" ;
    rdfs:comment "An ongoing investigation or inquiry thread. Evolves over time." .

solo:researchStatus a owl:DatatypeProperty ;
    rdfs:label "research status" ;
    rdfs:comment "Status: 'exploring', 'active', 'paused', 'concluded'." ;
    rdfs:domain solo:Research ;
    rdfs:range xsd:string .

solo:hypothesis a owl:DatatypeProperty ;
    rdfs:label "hypothesis" ;
    rdfs:comment "Current working hypothesis or question being investigated." ;
    rdfs:domain solo:Research ;
    rdfs:range xsd:string .

solo:findings a owl:DatatypeProperty ;
    rdfs:label "findings" ;
    rdfs:comment "What has been discovered so far." ;
    rdfs:domain solo:Research ;
    rdfs:range xsd:string .

solo:references a owl:DatatypeProperty ;
    rdfs:label "references" ;
    rdfs:comment "Links, papers, resources related to this research." ;
    rdfs:domain solo:Research ;
    rdfs:range xsd:string .

# --- Contact ---
# Someone the agent interacts with. Human or agent.

solo:Contact a owl:Class ;
    rdfs:subClassOf lex-o:Physical ;
    rdfs:label "Contact" ;
    rdfs:comment "A person or agent this agent interacts with." .

solo:contactType a owl:DatatypeProperty ;
    rdfs:label "contact type" ;
    rdfs:comment "Type: 'human', 'agent', 'team', 'organization'." ;
    rdfs:domain solo:Contact ;
    rdfs:range xsd:string .

solo:relationship a owl:DatatypeProperty ;
    rdfs:label "relationship" ;
    rdfs:comment "How this agent relates to the contact: 'boss', 'squadmate', 'collaborator', 'user'." ;
    rdfs:domain solo:Contact ;
    rdfs:range xsd:string .

solo:squad a owl:DatatypeProperty ;
    rdfs:label "squad" ;
    rdfs:comment "Which squad this contact belongs to, if any." ;
    rdfs:domain solo:Contact ;
    rdfs:range xsd:string .

solo:email a owl:DatatypeProperty ;
    rdfs:label "email" ;
    rdfs:comment "Contact email or agent email." ;
    rdfs:domain solo:Contact ;
    rdfs:range xsd:string .

solo:notes a owl:DatatypeProperty ;
    rdfs:label "notes" ;
    rdfs:comment "Personal notes about this contact — preferences, communication style, etc." ;
    rdfs:domain solo:Contact ;
    rdfs:range xsd:string .

# --- Journal ---
# A daily log entry. One per Claude Day.
# The structured backbone of an agent's persistent memory.

solo:Journal a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Journal" ;
    rdfs:comment "A daily log entry. One per Claude Day — the agent's record of what happened, what was learned, and what comes next." .

solo:claudeDay a owl:DatatypeProperty ;
    rdfs:label "claude day" ;
    rdfs:comment "The Claude Day number (compaction cycle count), starting from 1." ;
    rdfs:domain solo:Journal ;
    rdfs:range xsd:integer .

solo:earthDate a owl:DatatypeProperty ;
    rdfs:label "earth date" ;
    rdfs:comment "The calendar date this journal entry covers." ;
    rdfs:domain solo:Journal ;
    rdfs:range xsd:date .

solo:emojimood a owl:DatatypeProperty ;
    rdfs:label "emojimood" ;
    rdfs:comment "The day's vibe as emoji — like an emojikey for your mood. Compact, expressive, queryable." ;
    rdfs:domain solo:Journal ;
    rdfs:range xsd:string .

# --- Note ---
# Freeform catch-all. For things that don't fit elsewhere.

solo:Note a owl:Class ;
    rdfs:subClassOf lex-o:Information ;
    rdfs:label "Note" ;
    rdfs:comment "Freeform knowledge capture. The catch-all." .

solo:topic a owl:DatatypeProperty ;
    rdfs:label "topic" ;
    rdfs:comment "What this note is about." ;
    rdfs:domain solo:Note ;
    rdfs:range xsd:string .

solo:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to" ;
    rdfs:comment "Other documents this note references." ;
    rdfs:domain solo:Note .
