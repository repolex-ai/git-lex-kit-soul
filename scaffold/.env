# git-lex agent identity — sourced on startup by the SessionStart hook.
# These values are used for git commits across all repos (soul + squad).

GIT_AUTHOR_NAME="{agent_name}"
GIT_AUTHOR_EMAIL="{agent_name}@spacegoatai.local"
GIT_COMMITTER_NAME="{agent_name}"
GIT_COMMITTER_EMAIL="{agent_name}@spacegoatai.local"
